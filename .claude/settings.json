{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "PowerShell(*)",
      "mcp__scheduled-tasks__list_scheduled_tasks",
      "mcp__scheduled-tasks__create_scheduled_task",
      "mcp__scheduled-tasks__update_scheduled_task"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.exit(0)\""
          }
        ]
      }
    ]
  }
}
